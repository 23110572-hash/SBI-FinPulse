# === SBI FinPulse Backend Environment ===
# Copy this file to .env and fill in your keys.

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_google_gemini_api_key

# Groq (https://console.groq.com/keys)
# Three keys are spread across the five crew agents to stay under the
# 12K TPM per-key free-tier limit. Slots 2/3 fall back to slot 1 if blank.
#   GROQ_API_KEY    -> Profiler + Wellness
#   GROQ_API_KEY_2  -> Nudge Strategist + Compliance Officer
#   GROQ_API_KEY_3  -> Conversation Agent (crew + chat)
GROQ_API_KEY=your_groq_api_key
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# Hugging Face token with "Inference Providers" permission (RAG embeddings)
HF_TOKEN=your_hf_token

# Database — PostgreSQL (Neon) ONLY. No local SQLite.
# e.g. postgresql+psycopg2://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=your_neon_postgres_url

# Vector store
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_MODE=cloud
CHROMA_API_KEY=your_chroma_cloud_api_key
CHROMA_TENANT=your_chroma_tenant_id
CHROMA_DATABASE=SBI

# CORS
CORS_ORIGINS=http://localhost:3000

# Embeddings
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM model ids (override if needed)
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================
# Data provider: synthetic | sbi_sandbox | account_aggregator
# ============================================================
DATA_PROVIDER=synthetic

# SBI Innovation Hub / APIX sandbox (Round 2)
SBI_API_BASE=
SBI_API_KEY=
SBI_CLIENT_ID=
SBI_CLIENT_SECRET=

# RBI Account Aggregator (FIU side: Setu / Finvu / OneMoney / SahamatiNet)
AA_BASE_URL=
AA_CLIENT_ID=
AA_CLIENT_SECRET=
AA_FIU_ID=

# ============================================================
# Nudge delivery channels (real senders — fill to go live)
# ============================================================
# WhatsApp provider: meta | twilio
WHATSAPP_PROVIDER=meta
META_WA_TOKEN=
META_WA_PHONE_ID=

# Twilio (WhatsApp + SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# Email (SMTP) for email / app_notification channel.
# NOTE: many PaaS hosts (Render free tier, etc.) BLOCK outbound SMTP ports
# (25/465/587). Use the Resend HTTP API below in production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=FinPulse <no-reply@finpulse.local>

# Email (Resend HTTP API) — primary channel in production (sends over HTTPS,
# so it works where SMTP is blocked). Get a key at https://resend.com.
# RESEND_FROM must be a verified sender (or "onboarding@resend.dev" for tests).
RESEND_API_KEY=
RESEND_FROM=FinPulse <onboarding@resend.dev>

# If true, the engagement engine auto-sends fully-approved nudges (no human click)
AUTO_SEND_APPROVED=false

# ============================================================
# Proactive engagement scheduler
# ============================================================
ENABLE_SCHEDULER=false
SCHEDULER_INTERVAL_MINUTES=60
REANALYZE_AFTER_HOURS=12

# ============================================================
# Auth
# ============================================================
# Bearer token for staff console / nudge management / dashboard
STAFF_API_TOKEN=
# Require X-Customer-Token header on customer routes (true in production)
ENFORCE_CUSTOMER_SCOPE=false
